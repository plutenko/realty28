NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Нужен для API-роутов (создание публичных подборок).
# Не добавляй этот ключ в клиентский код.
SUPABASE_SERVICE_ROLE_KEY=

# Опционально: для npm run db:migrate и npm run check:setup (DDL в Supabase).
# Пароль из Dashboard → Settings → Database (не anon/service key).
# DATABASE_URL=postgresql://postgres:ВАШ_ПАРОЛЬ_БД@db.xxxxx.supabase.co:5432/postgres
# Либо пароль БД + NEXT_PUBLIC_SUPABASE_URL:
# SUPABASE_DB_PASSWORD=
#
# Скрипты: npm run db:migrate или ./scripts/run-migrations.sh (все .sql по порядку),
# npm run db:migrate:one -- 020_sources_parser_sheet_sync_meta.sql (один файл),
# npm run db:migrate:skip -- 00X_name.sql (только отметка в журнале),
# npm run check:setup, npm run db:migrate:list-skip,
# npm run db:migrate:bundle (сборка supabase/paste-migrations-supabase-sql-editor.sql для SQL Editor).

# Публичный bucket Supabase Storage для медиа
NEXT_PUBLIC_SUPABASE_BUCKET=realty-media

# Простой токен для доступа к /admin/media и API-роутам загрузки
ADMIN_UPLOAD_TOKEN=

# ========== Profitbase (/api/profitbase/*) ==========
# Без ручного обновления JWT: задайте ACCOUNT_ID + SITE_WIDGET_REFERER — сервер сам
# запрашивает https://sso.profitbase.ru/api/oauth2/token и кэширует access_token в памяти.

# Как найти NEXT_PUBLIC_PROFITBASE_ACCOUNT_ID:
# — В DevTools → Network откройте POST …/oauth2/token → Request Headers → X-Tenant-Id (число).
# — Или в payload JWT (если есть site_token): поле account.id.
# — Или в коде вставки виджета (Tilda / accountId в init).
NEXT_PUBLIC_PROFITBASE_ACCOUNT_ID=

# Как найти PROFITBASE_SITE_WIDGET_REFERER (обязательно для авто-JWT):
# — В Network → POST …/oauth2/token → Payload/form-data: поле referer (полный URL страницы с виджетом).
# — Должен совпадать с тем, как открыт сайт (http vs https, с/без www). Иначе SSO может вернуть 401.
# Пример: https://example.com или http://example.com/page
PROFITBASE_SITE_WIDGET_REFERER=

# API вашего аккаунта (не sso.profitbase.ru). Как найти:
# — Из любого запроса к каталогу: хост вида https://pbXXXXX.profitbase.ru
# — Или из JWT account.subdomain → https://{subdomain}.profitbase.ru
PROFITBASE_API_HOST=https://pb20366.profitbase.ru

# Необязательно: тот же хост, если /crm/api на другом URL (обычно = PROFITBASE_API_HOST)
# PROFITBASE_CRM_HOST=

# Origin iframe каталога (по умолчанию в коде https://smart-catalog.profitbase.ru)
# PROFITBASE_SITE_WIDGET_ORIGIN=https://smart-catalog.profitbase.ru

# Официальный ключ app-… из кабинета developer.profitbase.ru (для v4 без виджетного JWT)
PROFITBASE_API_APP_KEY=

# pbApiKey — как найти: откройте сайт с виджетом → Network → запрос к widget/smallGrid/iframe —
# в URL будет query pbApiKey=… (длинная hex-строка). Либо в коде вставки ProfitbaseWidget.
# Сервер-only вариант (не попадёт в бандл браузера): PROFITBASE_WIDGET_PB_API_KEY=
NEXT_PUBLIC_PROFITBASE_PB_API_KEY=
# PROFITBASE_WIDGET_PB_API_KEY=

# Запас: если SSO недоступен, вставьте access_token из ответа oauth2/token (без Bearer).
# NEXT_PUBLIC_PROFITBASE_TOKEN светит ключ клиенту — по возможности только PROFITBASE_CRM_TOKEN.
PROFITBASE_CRM_TOKEN=
# NEXT_PUBLIC_PROFITBASE_TOKEN=

# Редко нужно: переопределить client_id/secret для SSO (по умолчанию site_widget)
# PROFITBASE_SSO_CLIENT_ID=site_widget
# PROFITBASE_SSO_CLIENT_SECRET=site_widget
# PROFITBASE_SSO_GRANT_TYPE=site_widget
# PROFITBASE_SSO_TENANT_ID=   # то же что ACCOUNT_ID, если хотите сервер-only имя
# PROFITBASE_PB_DOMAIN=profitbase.ru

# ========== Google Sheets (шахматка, lib/syncGoogleSheetsFromSource) ==========
# Полный JSON service account в одну строку. Не коммить реальный ключ.
# В Google Sheets: «Поделиться» → добавьте email из поля client_email (роль Читатель).
# Если в /admin/sources подключён личный Google (OAuth), он используется первым; иначе — сервисный аккаунт.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# OAuth «Подключить Google» (консоль Google Cloud → APIs & Services → Credentials → OAuth 2.0).
# Тип приложения: Web. Redirect URI должен совпадать с продом/localhost.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google-sheets/callback

